{
    "name": "Valle Flores Invoice (sample, with custom module)",
    "keywords": ["VALLE FLORES S.A.S.", "contacto@valleflores.example"],
    "split_coordinates": [0.5],
    "non_fields": ["TOTAL"],
    "fields": {
        "tesseract": {
            "INVOICE_NUMBER": "FACTURA\\s*(\\d+)",
            "BOX_PLACES_COUNT": "CAJAS\\s*([\\d.]+)"
        },
        "tesseract_split": {
            "INVOICE_DATE": "FECHA\\s*(\\d{2}/\\d{2}/\\d{4})",
            "AVIA_TICKET": "GUIA\\s*([\\d -]+)"
        }
    }
}
